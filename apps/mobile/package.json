{
  "name": "@agromarket/mobile",
  "version": "1.0.0",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "test": "pnpm run typecheck",
    "e2e:smoke": "maestro test .maestro/flows/smoke-auth.yaml",
    "e2e:smoke:tabs-dev": "maestro test .maestro/flows/smoke-tabs-dev-login.yaml",
    "e2e:smoke:otp-api": "maestro test .maestro/flows/smoke-otp-api.yaml",
    "e2e:smoke:quick": "maestro test .maestro/flows/smoke-auth.yaml .maestro/flows/smoke-tabs-dev-login.yaml",
    "e2e:smoke:android": "maestro test --format junit --output .maestro/results/android .maestro/flows/smoke-auth.yaml",
    "format": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@agromarket/shared-utils": "workspace:*",
    "@agromarket/ui-components": "workspace:*",
    "@babel/runtime": "^7.29.2",
    "@expo/metro-runtime": "~3.2.3",
    "@expo/vector-icons": "^14.0.3",
    "@react-native-async-storage/async-storage": "1.23.1",
    "@react-native/assets-registry": "0.74.84",
    "@tanstack/react-query": "^5.62.8",
    "expo": "^51.0.0",
    "expo-asset": "^10.0.10",
    "expo-av": "~14.0.7",
    "expo-camera": "~15.0.9",
    "expo-constants": "~16.0.2",
    "expo-document-picker": "~12.0.2",
    "expo-file-system": "~17.0.1",
    "expo-font": "~12.0.10",
    "expo-haptics": "~13.0.1",
    "expo-image": "~1.13.0",
    "expo-image-picker": "~15.1.0",
    "expo-linking": "~6.3.1",
    "expo-location": "~17.0.1",
    "expo-modules-core": "~1.12.26",
    "expo-notifications": "~0.28.19",
    "expo-router": "~3.5.23",
    "expo-splash-screen": "~0.27.7",
    "expo-status-bar": "~1.12.1",
    "react": "18.2.0",
    "react-native": "0.74.5",
    "react-native-gesture-handler": "~2.16.2",
    "react-native-reanimated": "~3.10.1",
    "react-native-safe-area-context": "4.10.5",
    "react-native-screens": "3.31.1",
    "react-native-toast-message": "^2.2.0",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@types/react": "~18.2.79",
    "babel-preset-expo": "^11.0.15",
    "typescript": "^5.3.3"
  }
}
