{
  "name": "@agromarket/listing-service",
  "private": true,
  "scripts": {
    "dev": "prisma generate && tsx watch src/main.ts",
    "build": "prisma generate && tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "lint": "prisma generate && tsc -p tsconfig.json --noEmit",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "tsx --test tests/**/*.test.ts",
    "format": "node -e \"process.exit(0)\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.1",
    "prisma": "^6.19.3",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
