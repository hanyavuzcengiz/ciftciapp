NODE_ENV=development
# Web app (Next.js admin-panel)
NEXT_PUBLIC_API_URL=http://127.0.0.1:3000
NEXT_PUBLIC_ENABLE_MOCK_DATA=true
# Smoke (pnpm smoke:prod*): bos ise asagidaki sirayla NEXT / EXPO kullanilir
# SMOKE_API_URL=http://127.0.0.1:3000
# SMOKE_CHECK_METRICS=1: opsiyonel GET /metrics smoke kontrolu (gateway'de GATEWAY_PROMETHEUS_METRICS=1 gerekir)
# Gateway'de JWT'siz saglik (ornek): GET /health, /api/v1/payments/health, /api/v1/payments-secure/health, ...
# Mobil emülatör: 127.0.0.1; fiziksel Android: PC'nin LAN IP'si (örn. http://192.168.1.10:3000)
EXPO_PUBLIC_API_URL=http://127.0.0.1:3000
EXPO_PUBLIC_USER_SERVICE_URL=http://127.0.0.1:3001
# Expo Push: eas init sonrasi project UUID (app.config extra.eas.projectId)
EXPO_PUBLIC_EAS_PROJECT_ID=
# true: mock icerikler aktif, false: sadece canli API verisi
EXPO_PUBLIC_ENABLE_MOCK_DATA=true
# Production/release build'de mock veri varsayilan olarak kapali.
# Sadece zorunlu test senaryosunda acin:
# EXPO_PUBLIC_ALLOW_MOCK_IN_PROD=true
EXPO_PUBLIC_ENABLE_ADVANCED_SEARCH=true
EXPO_PUBLIC_ENABLE_AI_SUGGEST=true
GOOGLE_MAPS_API_KEY=
OPENAI_API_KEY=
# Fiziksel cihaz (Expo): PC IP ve port — örn. exp://192.168.1.10:8081,http://192.168.1.10:8081
CORS_ORIGINS=exp://localhost:8081,http://localhost:8081
# api-gateway: her yanitta x-request-id (istemci gonderdiyse korunur); proxyle hedef servislere iletilir
# GATEWAY_STRUCTURED_ACCESS_LOG=1: JSON http_access satirlari (Loki/ELK)
GATEWAY_STRUCTURED_ACCESS_LOG=0
# GATEWAY_PROMETHEUS_METRICS=1: GET /metrics (Prometheus text); prod'da sadece scrape agindan erisilebilir olsun
# GATEWAY_PROMETHEUS_METRICS=0
# user-service: JSON http_access log (gateway ile ayni alanlar)
USER_SERVICE_STRUCTURED_ACCESS_LOG=0
LISTING_SERVICE_STRUCTURED_ACCESS_LOG=0
MESSAGING_SERVICE_STRUCTURED_ACCESS_LOG=0
NOTIFICATION_SERVICE_STRUCTURED_ACCESS_LOG=0
OFFER_SERVICE_STRUCTURED_ACCESS_LOG=0
PAYMENT_SERVICE_STRUCTURED_ACCESS_LOG=0
SEARCH_SERVICE_STRUCTURED_ACCESS_LOG=0
AI_SERVICE_STRUCTURED_ACCESS_LOG=0
ADMIN_SERVICE_STRUCTURED_ACCESS_LOG=0
LISTING_SERVICE_URL=http://127.0.0.1:3002
MESSAGE_ENCRYPTION_KEY=change-me-32-chars-minimum!!
JWT_SECRET=replace-me
JWT_REFRESH_SECRET=replace-me-too
DATABASE_URL=postgresql://agromarket:agromarket@localhost:5432/agromarket
# Verification document storage (user-service)
# If S3 vars are set, uploads go to S3/MinIO. Otherwise local /uploads fallback is used.
# For MinIO examples:
# S3_ENDPOINT=http://127.0.0.1:9000
# S3_FORCE_PATH_STYLE=1
S3_BUCKET=
S3_REGION=eu-central-1
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_ENDPOINT=
S3_FORCE_PATH_STYLE=0
# Optional explicit public base URL for documents (without trailing slash)
# VERIFICATION_DOC_PUBLIC_BASE_URL=https://cdn.example.com/bucket-name
# user-service SQL migrasyonları: prisma/migrations 0001–0004 (0004 bildirim deep link sütunları)
# Uygulama: repo kökünde `.env` dosyası varken `pnpm db:user:migrate`
# Mesajları kalıcı tutmak için (user-service prisma migration 0002_chat_messaging sonrası aynı DB)
# MESSAGING_DATABASE_URL=postgresql://agromarket:agromarket@localhost:5432/agromarket
# Teklif ve bildirimler (migration 0003_app_offers_notifications_peer_reviews)
# OFFERS_DATABASE_URL=postgresql://agromarket:agromarket@localhost:5432/agromarket
# NOTIFICATIONS_DATABASE_URL=postgresql://agromarket:agromarket@localhost:5432/agromarket
# offer-service / messaging-service → bildirim kaydı (tam akış için açık tutun)
NOTIFICATION_SERVICE_URL=http://127.0.0.1:3005
# Expo push retry hardening (opsiyonel): 429/5xx veya ag hatasinda exponential backoff
# NOTIFICATION_PUSH_MAX_ATTEMPTS=3
# NOTIFICATION_PUSH_RETRY_BASE_MS=400
# listing-service (Prisma) — genelde DATABASE_URL ile aynı veritabanı; tablo adı listings_app
LISTING_DATABASE_URL=postgresql://agromarket:agromarket@localhost:5432/agromarket
REDIS_URL=redis://localhost:6379
MONGODB_URL=mongodb://localhost:27017/agromarket
ELASTICSEARCH_URL=http://localhost:9200
RABBITMQ_URL=amqp://localhost:5672
KAFKA_BROKER=localhost:9092
ADMIN_API_KEY=dev-admin-key
# Admin verification auth:
# 1) Legacy header mode: x-admin-token must match ADMIN_TOKEN
# Set 0 to disable legacy admin token auth completely.
ADMIN_LEGACY_TOKEN_ENABLED=1
ADMIN_TOKEN=change-me-admin-token
# 2) JWT role mode (preferred): Authorization: Bearer <token>, payload.role must match ADMIN_JWT_ROLE
ADMIN_JWT_ROLE=admin
# Optional strict JWT claims for admin tokens
# ADMIN_JWT_ISSUER=agromarket-auth
# ADMIN_JWT_AUDIENCE=agromarket-admin
# Optional IP allowlist (comma-separated). If set, admin endpoints only accept these IPs.
# ADMIN_IP_ALLOWLIST=127.0.0.1,::1
# Per-minute rate limit for verification admin endpoints
ADMIN_VERIFICATION_RATE_LIMIT=120
# Re-apply cooldown after rejected verification request (hours)
VERIFICATION_REAPPLY_COOLDOWN_HOURS=72
REQUEST_SIGNING_SECRET=dev-secret
# Production hardening flags (set only if you intentionally allow temporary fallbacks)
# SEARCH_ALLOW_MEMORY_FALLBACK=false
# NOTE: payment-service runtime blocks production startup when PAYMENT_ALLOW_INMEMORY=true
# PAYMENT_ALLOW_INMEMORY=false
# payment provider modu: mock (default) | live
# PAYMENT_PROVIDER_MODE=mock
# live modda ilgili provider icin base url + api key birlikte set edilmelidir
# PAYMENT_IYZICO_BASE_URL=https://sandbox-api.iyzico.com
# PAYMENT_IYZICO_API_KEY=
# PAYMENT_STRIPE_BASE_URL=https://api.stripe.com
# PAYMENT_STRIPE_API_KEY=
# PAYMENT_PSP_TIMEOUT_MS=8000
# payment webhook replay korumasi: x-timestamp icin kabul edilen max saat farki (saniye)
# PAYMENT_WEBHOOK_TOLERANCE_SECONDS=300
# payment request idempotency key limiti (x-idempotency-key)
# PAYMENT_IDEMPOTENCY_KEY_MAX_LENGTH=128
PYTHON_AI_URL=http://127.0.0.1:8010
